{
  "expo": {
    "name": "Apple Pulse Timer / Orbit Dial",
    "slug": "applepulsetimerorbitdial",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app_icon.png",
    "scheme": "applepulsetimerorbitdial",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "Apple Pulse Timer / Orbit Dialは、深い集中と生産性を追求するためのミニマルなタイマーアプリです。触覚的なフィードバックと直感的な操作で、デジタルデトックスを促し、あなたのフロー状態をサポートします。ポモドーロテクニックやカスタムタイマーで、仕事、学習、瞑想など、あらゆる活動の質を高めましょう。洗練されたデザインとAppleエコシステムとのシームレスな統合で、集中力を次のレベルへと引き上げます。",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zerocode.applepulsetimerorbitdial",
      "buildNumber": "1",
      "infoPlist": {
        "NSMotionUsageDescription": "このアプリは、タイマー操作のためにデバイスのフリップを検出するためにモーションセンサーを使用します。",
        "BGTaskSchedulerPermittedIdentifiers": [
          "$(PRODUCT_BUNDLE_IDENTIFIER).background-task"
        ],
        "NSSiriUsageDescription": "Siriを使ってタイマーを開始、一時停止、リセットできます。",
        "NSUserNotificationsUsageDescription": "タイマーの終了や休憩のリマインダーのために通知を送信します。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.zerocode.applepulsetimerorbitdial",
      "versionCode": 1,
      "permissions": [
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff",
          "sounds": [
            "./assets/sounds/timer-complete.wav"
          ]
        }
      ]
    ],
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#FFFBEB",
      "resizeMode": "contain"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e2588e7c-d3de-4da1-89d2-4a9a3d0c4ec9"
      }
    },
    "owner": "yoshi-san"
  }
}
