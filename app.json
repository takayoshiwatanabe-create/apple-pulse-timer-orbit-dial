{
  "expo": {
    "name": "Apple Pulse Timer / Orbit Dial",
    "slug": "applepulsetimerorbitdial",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app_icon.png",
    "scheme": "applepulsetimerorbitdial",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zerocode.applepulsetimerorbitdial"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.zerocode.applepulsetimerorbitdial"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#FFFBEB"
    }
  }
}